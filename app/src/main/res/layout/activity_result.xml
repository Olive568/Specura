<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ResultActivity">

    <ImageView
        android:id="@+id/resultImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@string/result_image"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/infoContainer"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:minHeight="240dp"
        android:background="@drawable/result_popup_background"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/resultTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/detection_result"
            android:textColor="#111111"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <ScrollView
            android:id="@+id/resultScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/resultContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Material First -->
                <TextView
                    android:id="@+id/resultMaterial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="Material: Concrete" />

                <TextView
                    android:id="@+id/resultMaterialConfidence"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="#111111"
                    android:textSize="14sp"
                    tools:text="Confidence: 82.30%" />

                <TextView
                    android:id="@+id/resultTopMaterials"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#111111"
                    android:textSize="13sp"
                    tools:text="Top 3:\n1. Concrete - 82.30%\n2. Brick - 11.25%\n3. Metal - 6.45%" />

                <TextView
                    android:id="@+id/resultLocationTag"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#111111"
                    android:textSize="15sp"
                    tools:text="Location Tag: Wall A" />

                <TextView
                    android:id="@+id/resultLedgerStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#111111"
                    android:textSize="15sp"
                    tools:text="Status: DEFECT VERIFIED" />

                <TextView
                    android:id="@+id/resultSeverity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="MODERATE" />

                <TextView
                    android:id="@+id/resultVerifiedDefects"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="#111111"
                    android:textSize="14sp"
                    tools:text="No Defects" />

                <TextView
                    android:id="@+id/resultHScore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="#111111"
                    android:textSize="14sp"
                    tools:text="H-Score: 0.8450" />

                <TextView
                    android:id="@+id/resultEScore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#111111"
                    android:textSize="14sp"
                    tools:text="E-Score: 0.4420" />

                <TextView
                    android:id="@+id/resultTimestamp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#111111"
                    android:textSize="14sp"
                    tools:text="Timestamp: May 18, 2026 09:45" />

            </LinearLayout>
        </ScrollView>

        <Button
            android:id="@+id/btnShowDefects"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="#607D8B"
            android:text="@string/show_defects"
            android:textColor="#FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#B00020"
                android:text="@string/delete"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnKeep"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:backgroundTint="#607D8B"
                android:text="@string/close"
                android:textColor="#FFFFFF" />

        </LinearLayout>

        <Button
            android:id="@+id/btnClose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="#444444"
            android:text="@string/close"
            android:textColor="#FFFFFF"
            android:visibility="gone" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
